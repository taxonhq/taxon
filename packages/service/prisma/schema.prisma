generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 枚举类型 ──────────────────────────────────────────────────
enum TagSource {
  manual
  ai
  system
  import
}

enum TagStatus {
  active
  pending
  rejected
}

enum ApiRole {
  reader    // 只读
  writer    // reader + 实体注册/打标
  reviewer  // writer + 审核 AI 标签
  admin     // 全权限，含分组/标签 CRUD
}

// ── API Token ─────────────────────────────────────────────────
// 服务级 API Key，用于业务服务和审核工具的身份认证。
// 不存明文：tokenHash = SHA-256(rawToken)，只在创建时返回一次明文。
//
// 字段说明：
//   name       — 人类可读标识，如 "restaurant-service"
//   tokenHash  — SHA-256 十六进制，用于请求时比对
//   role       — 权限角色，见 ApiRole enum
//   scopes     — entityType 白名单，空数组表示全部放行
//   lastUsedAt — 最近一次认证成功时间（异步更新，不阻塞请求）
//   revokedAt  — 撤销时间戳；非 null 表示已撤销，认证直接拒绝
model ApiToken {
  id         String    @id @default(cuid())
  name       String
  tokenHash  String    @unique
  role       ApiRole
  scopes     String[]
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  reviews    EntityTagReview[]
}

// ── 实体注册表 ────────────────────────────────────────────────
// tag-service 的实体生命周期登记簿。业务服务在创建实体时注册，删除时注销。
// tag-service 对实体的了解仅限于 entityType + entityId，不存储业务字段。
// 实体注销时通过 CASCADE 自动清除所有 EntityTag 关联。
//
// 字段说明：
//   entityType   — 实体类型标识，如 "dish"、"dining"
//   entityId     — 业务主键（cuid），字符串引用，无跨库 FK 约束
//   registeredAt — 首次注册时间
model RegisteredEntity {
  entityType   String
  entityId     String
  registeredAt DateTime    @default(now())
  entityTags   EntityTag[]

  @@id([entityType, entityId])
  @@index([entityType])
}

// ── 实体-标签关联表 ────────────────────────────────────────────
// 记录"哪个实体被打了哪个标签"，是 tag-service 的核心关联表。
// 双向 CASCADE：实体注销或标签删除时自动清除关联。
//
// 字段说明：
//   source     — 打标来源：manual（人工）| ai（AI推断）| system（系统）| import（批量导入）
//   confidence — AI 置信度 0~1，非 AI 来源时为 null
//   status     — 关联状态：active（生效）| pending（待审核）| rejected（已拒绝）
//                AI 打标默认 pending，人工打标默认 active
//   createdAt  — 打标时间
model EntityTag {
  tagId      String
  tag        Tag              @relation(fields: [tagId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  entity     RegisteredEntity @relation(fields: [entityType, entityId], references: [entityType, entityId], onDelete: Cascade)
  source         TagSource  @default(manual)
  confidence     Float?
  status         TagStatus  @default(active)
  createdAt      DateTime   @default(now())
  reviewedAt     DateTime?                    // 最后一次审核时间
  reviewerId     String?                      // 最后一次审核者 ApiToken.id（软引用）
  reviewNote     String?                      // 最后一次审核备注
  previousStatus TagStatus?                   // 上一次状态（供撤销参考）

  reviews        EntityTagReview[]

  @@id([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([entityType, entityId, status])
  @@index([tagId])
  @@index([tagId, status])
  @@index([status, entityType])
  // 审核队列分页：WHERE status=? ORDER BY createdAt DESC
  @@index([status, createdAt(sort: Desc)])
}

// ── 标签 ──────────────────────────────────────────────────────
// 隶属于某个 TagGroup 的具体标签。
// slug 和 name 在同一分组内、仅对未删除记录唯一。
//
// 唯一性由 PostgreSQL 部分唯一索引保证（WHERE deletedAt IS NULL），
// 见 migration 20260521000000_soft_delete_partial_unique_index：
//   - Tag_groupId_slug_active_key
//   - Tag_groupId_name_active_key
// Prisma schema 无法表达 partial index，故此处不写 @@unique。
// 不要重新加回 @@unique —— 那会变成全量约束，软删除记录会重新占用名字空间。
//
// 字段说明：
//   slug      — URL 友好标识符，同分组内未删除记录唯一，最多 100 字符
//   name      — 显示名称，同分组内未删除记录唯一，最多 50 字符
//   deletedAt — 软删除时间戳，null 表示未删除；软删除不再改写 slug/name
model Tag {
  id          String    @id @default(cuid())
  groupId     String
  group       TagGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Tag?      @relation("TagHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Tag[]     @relation("TagHierarchy")
  slug        String
  name        String
  description String?
  sortOrder   Int       @default(0)
  // 物化路径，格式 /slug1/slug2/slug3/，便于高效子孙查询（LIKE 前缀匹配）
  path        String    @default("")
  depth       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  entityTags  EntityTag[]
  aliases     TagAlias[]

  @@index([groupId])
  @@index([groupId, parentId])
  @@index([path])
}

// ── 标签别名 ───────────────────────────────────────────────────
// 同一 tag 可有多个别名（如 "麻辣" = "辣" = "spicy"）。
// 同一 group 内 alias 不能挂到两个不同 tag（应用层校验）。
model TagAlias {
  id        String   @id @default(cuid())
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  alias     String
  source    String   @default("manual") // manual | ai | import
  createdAt DateTime @default(now())

  @@unique([tagId, alias])
  @@index([alias])
}

// ── 标签分组（维度）──────────────────────────────────────────
// 对标签进行维度划分，如"菜系"、"口味"。
// allowMultiple 为默认规则，可通过 TagGroupEntityRule 按实体类型覆盖。
//
// slug / name 仅对未删除记录唯一，由 PostgreSQL 部分唯一索引保证：
//   - TagGroup_slug_active_key   (WHERE deletedAt IS NULL)
//   - TagGroup_name_active_key   (WHERE deletedAt IS NULL)
// 见 migration 20260521000000_soft_delete_partial_unique_index。
// 不要给 slug / name 加回 @unique —— 那会变成全量约束。
//
// 字段说明：
//   entityScopes  — 允许使用本分组标签的实体类型；空数组=通用
//   allowMultiple — 默认：单实体是否可持有本分组多个标签
//   deletedAt     — 软删除时间戳；软删除不再改写 slug/name
model TagGroup {
  id            String    @id @default(cuid())
  slug          String
  name          String
  description   String?
  entityScopes  String[]
  allowMultiple Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tags        Tag[]
  entityRules TagGroupEntityRule[]
}

// ── 分组实体类型规则 ──────────────────────────────────────────
// 覆盖 TagGroup.allowMultiple 的按实体类型独立配置。
// 若存在匹配记录，优先于 TagGroup.allowMultiple。
//
// 示例：菜系分组对 "dish" allowMultiple=false，对 "dining" allowMultiple=true。
model TagGroupEntityRule {
  groupId       String
  group         TagGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  entityType    String
  allowMultiple Boolean

  @@id([groupId, entityType])
}

// ── 合并操作日志 ──────────────────────────────────────────────
// 记录每次 merge 的操作结果，保留审计轨迹。
// 软引用 tag ID（tag 可能被后续删除），不加 FK。
model TagMergeLog {
  id              String   @id @default(cuid())
  targetTagId     String
  sourceTagIds    String[]
  entityTagsMoved Int
  aliasesMoved    Int
  mergedAt        DateTime @default(now())
}

// ── 跨分组迁移日志 ────────────────────────────────────────────
// 记录每次 move（含子孙节点数量），保留审计轨迹。
model TagMoveLog {
  id          String   @id @default(cuid())
  tagId       String
  fromGroupId String
  toGroupId   String
  tagsMoved   Int      // 含子孙节点数量
  movedAt     DateTime @default(now())
}

// ── 系统配置（键值存储）─────────────────────────────────────────
// 通用键值存储，用于保存系统级配置，如仪表盘布局。
// value 使用 Json 类型，支持任意结构。
model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ── 审核历史 ───────────────────────────────────────────────────
// 每次 PATCH status 操作生成一条记录，完整保留操作轨迹。
// entityTag 通过复合主键 (tagId, entityType, entityId) 关联。
// reviewer  通过 ApiToken.id 关联；dev-bypass 时 reviewerId 为 null。
model EntityTagReview {
  id         String    @id @default(cuid())
  tagId      String
  entityType String
  entityId   String
  entityTag  EntityTag @relation(fields: [tagId, entityType, entityId], references: [tagId, entityType, entityId], onDelete: Cascade)
  reviewerId String?
  reviewer   ApiToken? @relation(fields: [reviewerId], references: [id], onDelete: SetNull)
  fromStatus TagStatus
  toStatus   TagStatus
  note       String?
  reviewedAt DateTime  @default(now())

  @@index([tagId, entityType, entityId, reviewedAt])
  @@index([reviewerId, reviewedAt])
}
