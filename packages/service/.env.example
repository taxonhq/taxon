# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/taxon?schema=public"

# Service port (default: 3300)
PORT=3300

# Day-boundary timezone offset in minutes east of UTC, used by all dashboard
# "today"/"trend" aggregations (#148). Default 0 = UTC. Set to align metrics with
# the operators' local day (e.g. China Standard Time UTC+8 → 480). Fixed offset,
# no DST handling — exact for zones without DST. Keep in sync with the console's
# NEXT_PUBLIC_APP_TZ_OFFSET_MIN.
# APP_TZ_OFFSET_MIN=480

# Bearer token for API authentication.
# Required in production; if unset in development, auth is DISABLED.
# API_TOKEN="your-secret-token"

# Allowed CORS origins, comma-separated.
# In production this MUST be set, otherwise all cross-origin requests are rejected.
# Use "*" to explicitly allow any origin.
# CORS_ORIGINS="http://localhost:3400,https://your-console.example.com"

# Master key for encrypting LLM API tokens at rest (in SystemConfig table).
# Any non-empty string works (SHA-256 derived to 32 bytes). Rotate carefully:
# changing this invalidates all previously-encrypted secrets.
# Generate one with: openssl rand -base64 48
LLM_MASTER_KEY="change-me-to-a-random-secret"

# Pre-filled Bearer token shown in the Scalar /docs UI.
# Set to a reader-role API token in development so you can try endpoints without
# manually entering a token each time.  Leave unset in production.
# SCALAR_BEARER_TOKEN="taxon_dev_xxxxxxxxxxxxxxxx"

# Database used by the test suite (vitest).
# Needs permission to CREATE/DROP SCHEMA — each test run uses an isolated schema.
# Can point at any throwaway Postgres; never your production database.
# TEST_DATABASE_URL="postgresql://user:password@localhost:5432/taxon_test"
