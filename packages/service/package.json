{
  "name": "tag-service",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:spec": "tsx scripts/export-spec.ts",
    "check:openapi": "tsx scripts/check-openapi-drift.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^1.4.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "hono": "^4.12.15",
    "openai": "^6.39.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pinyin": "^4.0.0",
    "prisma": "^6.19.3",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "@types/pinyin": "^2.10.2",
    "pg": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
